# Notion (required for live workspace data)
# Create an Internal Integration and copy its secret (starts with secret_ or ntn_)
NOTION_API_KEY=your_notion_api_key_here

# LLM (optional)
# Knowledge Graph provider order in auto mode:
# Gemini -> Ollama/local -> NVIDIA NIM -> built-in deterministic graph method.
VAULTMIND_LLM_PROVIDER=your_preferred_provider_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=your_model_here
OPENROUTER_BASE_URL=#
# Gemini / Google AI Studio (primary for Knowledge Graph when set)
GEMINI_API_KEY=your_geminiai_api_key_here
GEMINI_MODEL=your_gemini_model_here
# Increase if Gemini responses get truncated (incomplete JSON).
# This is mainly for classifier batches.
VAULTMIND_LINKING_MAX_TOKENS=your_desired_max_tokens_here
# Global default cap for Gemini (optional). Linking uses VAULTMIND_LINKING_MAX_TOKENS when set.
GEMINI_MAX_OUTPUT_TOKENS=your_desired_max_output_tokens_here

# Ollama local config (first fallback for Knowledge Graph)
VAULTMIND_OLLAMA_URL=your_ollama_url_here
VAULTMIND_OLLAMA_MODEL=your_ollama_model_here
VAULTMIND_OLLAMA_MODELS=your_ollama_models_here
VAULTMIND_OLLAMA_TIMEOUT_MS=your_desired_timeout_in_ms_here

# NVIDIA NIM (second remote fallback for Knowledge Graph)
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here
NVIDIA_NIM_MODEL=your_nvidia_nim_model_here
NVIDIA_NIM_MAX_TOKENS=your_desired_max_tokens_here

# Cap Knowledge Graph classification to avoid long runs.
VAULTMIND_CLASSIFIER_BUDGET_MS=your_desired_budget_in_ms_here
# GitHub Models (optional)
# Used only for non-graph structured calls, or when VAULTMIND_LLM_PROVIDER=github.
# Use a GitHub PAT/fine-grained token with Models read permission.
# Do not use a Copilot OAuth token from AppData.
GITHUB_MODELS_MODEL=your_desired_github_model_here
GITHUB_MODELS_BASE_URL=your_github_models_base_url_here
# Embeddings (optional)
# Python sidecar (recommended): BGE-small embeddings + FAISS ANN.
EMBEDDINGS_PROVIDER=your_embeddings_provider_here
EMBEDDINGS_BASE_URL=your_embeddings_base_url_here
EMBEDDINGS_MODEL=your_embeddings_model_here
